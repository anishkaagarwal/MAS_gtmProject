OUTMATE_LLM_PROVIDER=openai 

# Get your free API key from: https://aistudio.google.com/apikey
OUTMATE_LLM_API_KEY="your api key goes here"
# Gemini model — each model has its own daily quota (20 req/day on free tier)
# Options: gemini-2.5-flash-lite, gemini-2.5-flash, gemini-2.0-flash, gemini-3.1-flash-lite-preview
OUTMATE_LLM_MODEL="gpt-5-mini"

OUTMATE_LLM_TEMPERATURE=1
OUTMATE_API_PORT=8000
OUTMATE_LOG_LEVEL=INFO

#it supports 3 providers - Groq, Gemini, OpenAI. You can set the provider and the corresponding API key in the .env file. 

